{
  "name": "@tasteee/replicate",
  "version": "0.0.11",
  "private": false,
  "description": "Concatenate globbed files into a single markdown file, or reconstruct from one.",
  "type": "module",
  "bin": {
    "replicate": "./dist/index.mjs"
  },
  "scripts": {
