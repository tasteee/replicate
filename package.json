    "dev": "tsdown --watch",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "glob": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.5.0"
  }
}
